<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patent & Trademark Search</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 15px;
        }

        .search-container {
            background: #ffffff;
            width: 100%;
            max-width: 900px;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(0,0,0,0.3);
        }

        h2 {
            text-align: center;
            color: #0f2027;
            margin-bottom: 20px;
        }

        form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 15px;
        }

        label {
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 5px;
            display: block;
        }

        input, select {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

        .btn-group {
            grid-column: 1 / -1;
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        button {
            padding: 12px 35px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            cursor: pointer;
            color: white;
        }

        .search-btn {
            background-color: #203a43;
        }

        .reset-btn {
            background-color: #6c757d;
        }

        button:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body>

<div class="search-container">
    <h2>Patent & Trademark Search</h2>

    <form onsubmit="return submitSearch()">

        <!-- IP Type -->
        <div>
            <label>IP Type</label>
            <select id="ipType">
                <option value="">Select IP Type</option>
                <option>Patent</option>
                <option>Trademark</option>
            </select>
        </div>

        <!-- Keyword -->
        <div>
            <label>Keyword</label>
            <input type="text" id="keyword" placeholder="Title / Abstract / Trademark name">
        </div>

        <!-- Assignee -->
        <div>
            <label>Assignee / Owner</label>
            <input type="text" id="assignee" placeholder="Company or Organization">
        </div>

        <!-- Inventor -->
        <div>
            <label>Inventor</label>
            <input type="text" id="inventor" placeholder="Inventor name">
        </div>

        <!-- Jurisdiction -->
        <div>
            <label>Jurisdiction</label>
            <select id="jurisdiction">
                <option value="">Select Jurisdiction</option>
                <option>United States (USPTO)</option>
                <option>India (IPO)</option>
                <option>European Union (EPO)</option>
                <option>Japan (JPO)</option>
                <option>China (CNIPA)</option>
                <option>WIPO (PCT)</option>
            </select>
        </div>

        <!-- Filing Year -->
        <div>
            <label>Filing Year</label>
            <select id="year">
                <option value="">Select Year</option>
                <option>2025</option>
                <option>2024</option>
                <option>2023</option>
                <option>2022</option>
                <option>2021</option>
            </select>
        </div>

        <!-- Buttons -->
        <div class="btn-group">
            <button type="submit" class="search-btn">Search</button>
            <button type="reset" class="reset-btn">Reset</button>
        </div>

    </form>
</div>

<script>
    function submitSearch() {

        const fields = [
            "ipType",
            "keyword",
            "assignee",
            "inventor",
            "jurisdiction",
            "year"
        ];

        const isAnyFieldFilled = fields.some(id =>
            document.getElementById(id).value.trim() !== ""
        );

        if (!isAnyFieldFilled) {
            alert("Please enter at least one search parameter.");
            return false;
        }

        alert("Search submitted successfully!\nRedirecting to Search List Page...");
        // window.location.href = "search-list.html";
        return false;
    }
</script>

</body>
</html>
